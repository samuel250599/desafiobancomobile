# BrowserStack Credentials
BROWSERSTACK_USERNAME=your_username
BROWSERSTACK_ACCESS_KEY=your_access_key

# App URL (será preenchido após upload)
BROWSERSTACK_APP_URL=bs://<app_url>

# Local Testing
BROWSERSTACK_LOCAL=true
BROWSERSTACK_LOCAL_IDENTIFIER=mobile_tests

# Build Info
BUILD_NAME=Mobile Automation Build
PROJECT_NAME=Native Demo App Tests