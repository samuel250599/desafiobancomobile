{
  "name": "native-demo-app-tests",
  "version": "1.0.0",
  "description": "Mobile automation tests for WebdriverIO Native Demo App",
  "scripts": {
    "test": "wdio wdio.conf.js",
    "test:android": "wdio config/wdio.android.conf.js",
    "test:ios": "wdio config/wdio.ios.conf.js",
    "test:browserstack": "wdio config/wdio.browserstack.conf.js",
    "test:smoke": "wdio wdio.conf.js --grep @smoke",
    "test:regression": "wdio wdio.conf.js --grep @regression",
    "test:login": "wdio wdio.conf.js --spec tests/specs/login.spec.js",
    "test:forms": "wdio wdio.conf.js --spec tests/specs/forms.spec.js",
    "test:swipe": "wdio wdio.conf.js --spec tests/specs/swipe.spec.js",
    "test:drag": "wdio wdio.conf.js --spec tests/specs/drag.spec.js",
    "test:navigation": "wdio wdio.conf.js --spec tests/specs/navigation.spec.js",
    "upload:browserstack": "node scripts/upload-to-browserstack.js",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report",
    "allure:serve": "allure serve allure-results",
    "lint": "eslint src tests --ext .js",
    "clean": "rm -rf allure-results allure-report"
  },
  "keywords": [
    "mobile-automation",
    "webdriverio",
    "appium",
    "mocha",
    "allure",
    "browserstack"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@wdio/allure-reporter": "^8.36.1",
    "@wdio/appium-service": "^8.36.1",
    "@wdio/browserstack-service": "^8.36.1",
    "@wdio/cli": "^8.36.1",
    "@wdio/local-runner": "^8.36.1",
    "@wdio/mocha-framework": "^8.36.1",
    "@wdio/spec-reporter": "^8.36.1",
    "allure-commandline": "^2.29.0",
    "appium": "^2.5.4",
    "appium-uiautomator2-driver": "^3.0.0",
    "appium-xcuitest-driver": "^7.0.0",
    "chai": "^4.4.1",
    "dotenv": "^16.4.5",
    "eslint": "^8.57.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}